# 开发环境配置

# API基础URL
VITE_API_BASE_URL=http://localhost:3001/api

# 是否使用真实API
VITE_USE_REAL_API=true

# 应用标题
VITE_APP_TITLE=悦社动态社区

# ==================== 生产环境配置 ====================
# 请复制此文件为 .env.production 并修改以下配置：
# 
# API基础URL (修改为你的实际API地址)
# VITE_API_BASE_URL=https://api.yoursite.com/api
# 
# 例如：你的网站是 https://yoursite.com
# API后端运行在 https://api.yoursite.com
# 则 VITE_API_BASE_URL=https://api.yoursite.com/api
